# Tachyon 연결 설정 예시
# 이 파일을 복사해서 config.env 를 만들고 실제 값을 입력하세요:
#   cp config.env.example config.env

# ── Tachyon 연결 ──────────────────────────────────────────────
TACHYON_IP="192.168.0.x"
TACHYON_PW="your_password_here"
STREAM_PORT=8080

# ── NAS API ───────────────────────────────────────────────────
NAS_API_URL="http://192.168.0.x:8000"
# NAS API 인증 시크릿 (nas/.env의 API_SECRET 과 동일하게 설정)
API_SECRET="your_api_secret_here"

# ── 카메라 식별자 (다중 카메라 사용 시 구분용) ─────────────────
CAMERA_ID="tachyon-01"

# ── YOLO 설정 ─────────────────────────────────────────────────
# 모델: yolo11n (가장 빠름) / yolo11s / yolov8n
YOLO_MODEL=yolo11n.pt
# 추론 이미지 크기 (320=3.8FPS/Tachyon, 416=1.6FPS, 640=0.7FPS)
YOLO_IMGSZ=320

# ── 카운팅 라인 (0.0~1.0, 화면 너비 비율) ────────────────────
COUNTING_LINE_X=0.5

# ── 응급차 분류 (추후 Roboflow API 키 발급 시 추가) ──────────
# ROBOFLOW_API_KEY=""
# ROBOFLOW_MODEL_ID="emergency-vehicle-detection/1"
